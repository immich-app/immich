# Copy to immich-test.env and adjust paths/passwords. immich-test.env is gitignored.
# Used by: docker compose -f docker-compose.immich-test.yml --env-file immich-test.env up -d
# See docker/README.md and server/TESTING_VIDEO_FACE_DETECTION.md

UPLOAD_LOCATION=./immich-test-runtime/upload
DB_DATA_LOCATION=./immich-test-runtime/postgres

IMMICH_VERSION=release

# Use only A–Z, a–z, 0–9 for DB_PASSWORD (Immich requirement)
DB_PASSWORD=change-me-to-a-random-string
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
